# URL base de la API (sin barra final; suele terminar en /api)
#
# Desarrollo local (proxy Vite): deja vacío o comenta la línea.
# PHP built-in: http://localhost:8000/api
#
# IP pública (router reenvía puerto al PC o VPS): sustituye por tu IP y puerto
# VITE_API_URL=http://203.0.113.50:8000/api
#
VITE_API_URL=http://localhost:8000/api
